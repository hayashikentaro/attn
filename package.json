{
  "name": "attn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3999",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check:env": "tsx scripts/check-env.ts",
    "deploy:checklist": "tsx scripts/deploy-checklist.ts",
    "migrate": "sh -c 'for file in supabase/migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$file\"; done'",
    "seed": "tsx scripts/seed-notifications.ts",
    "smoke:e2e": "tsx scripts/smoke-e2e.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tsx": "latest",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
